{
  "$schema": "../gen/schemas/permission-schema.json",
  "permission": [
    {
      "identifier": "main-commands",
      "description": "Allow main window commands",
      "commands": {
        "allow": [
          "verify_hello",
          "lock_screen",
          "emergency_unlock",
          "close_app",
          "get_lock_state",
          "get_now_playing_snapshot",
          "control_now_playing",
          "hide_settings_window",
          "get_settings",
          "save_settings"
        ]
      }
    }
  ]
}
