{
  "name": "qylock-windows",
  "private": false,
  "version": "0.2.2",
  "description": "Windows tray lock screen app built with Tauri and React.",
  "author": "minseok",
  "license": "GPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/minseokk7/qylock-windows.git"
  },
  "bugs": {
    "url": "https://github.com/minseokk7/qylock-windows/issues"
  },
  "homepage": "https://github.com/minseokk7/qylock-windows",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "installer:dev": "vite --config vite.installer.config.ts",
    "installer:build": "tsc -p tsconfig.installer.json && vite build --config vite.installer.config.ts",
    "installer:tauri:dev": "npm run installer:build && cargo run --manifest-path src-tauri-installer/Cargo.toml",
    "installer:tauri:build": "npm run installer:build && cargo build --release --manifest-path src-tauri-installer/Cargo.toml",
    "preview": "vite preview",
    "tauri": "tauri"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "@tauri-apps/cli": "^2"
  }
}
