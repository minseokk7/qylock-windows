{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "qylock-installer",
  "version": "0.2.1",
  "identifier": "com.minseok.qylock-installer",
  "build": {
    "beforeBuildCommand": "npm run installer:build",
    "frontendDist": "../dist-installer"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "qylock installer",
        "width": 980,
        "height": 640,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "../src-tauri/icons/32x32.png",
      "../src-tauri/icons/128x128.png",
      "../src-tauri/icons/icon.ico"
    ]
  }
}
